# Synapse Cell — Environment Variables
#
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── API Authentication ──────────────────────────────────────
# API key for the Cell gateway (used by SDK in HTTP mode)
SYNAPSE_API_KEY=test_key

# ── Gateway Configuration ───────────────────────────────────
# Port the gateway listens on
SYNAPSE_PORT=8002

# ── Benchmarking ────────────────────────────────────────────
# E2B API key for head-to-head benchmarks (optional)
# Get one at https://e2b.dev
# E2B_API_KEY=e2b_...

# Cell API key/URL for benchmark scripts
CELL_API_KEY=test_key
CELL_API_URL=http://localhost:8002

# ── Licensing ───────────────────────────────────────────────
# Pro license cert (enables persistent sessions in PyO3 mode)
# SYNAPSE_LICENSE_CERT=...

# ── Local Mode ──────────────────────────────────────────────
# Override template directory for Wasm runtimes
# CELL_TEMPLATE_DIR=/path/to/templates

# Override data directory for cell storage
# CELL_DATA_DIR=/tmp/synapse_cells/

# Suppress persistent mode warning in local mode
# CELL_SUPPRESS_PERSISTENT_WARNING=1
